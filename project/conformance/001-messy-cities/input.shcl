# Indented style
base               : Chicago
	metrics:
		Population : 30200
		Weather    : Hot,Cold, Lousy , "All around not that great"

# Inline style
base:["Cleveland, OH"].metrics.population: 700  # Why only 700?
base:[Boston].metrics.population                # Empty value
base : [ Philly ] . metrics.population: 1024

# Redundant path (collapses into Chicago)
base               : Chicago
	metrics:
		square-miles: 300
