field: title
	type: string
	required: yes
field: launched
	type: datetime
field: server
	repeat: 1, 4
field: "server[*].port"
	type: int
	required: yes
	min: 1
	max: 65535
field: "server[*].host"
	type: string
	required: yes
field: "server[*].region"
	type: string-array
field: "server[*].region"
	allowed: us, eu, apac
field: timeouts
	type: int-array
	min: 1
	max: 600
field: motd
	type: raw
field: debug
	type: bool
